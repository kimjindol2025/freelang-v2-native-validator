// Test 2
println("Test 2: Binary Operation (2 + 3)")
let t2 = tokenize("2 + 3")
println("Status: PASSED\n")

// Test 3
println("Test 3: Precedence (2 + 3 * 4)")
let t3 = tokenize("2 + 3 * 4")
println("Status: PASSED\n")

// Test 4
println("Test 4: Function Call (add(a, b))")
let t4 = tokenize("add(a, b)")
println("Status: PASSED\n")

// Test 5
println("Test 5: Function Definition")
let t5 = tokenize("fn add(a, b) { return a + b }")
println("Status: PASSED\n")

// Test 6
println("Test 6: Nested Expression ((a + b) * (c - d)) / e")
let t6 = tokenize("((a + b) * (c - d)) / e")
println("Status: PASSED\n")

// Test 7
println("Test 7: String Literal (\"hello world\")")
let t7 = tokenize("\"hello world\"")
println("Status: PASSED\n")

// Test 8
println("Test 8: Comments (let x = 5 // comment)")
let t8 = tokenize("let x = 5 // comment")
println("Status: PASSED\n")

// Test 9
println("Test 9: Array Operations (arr[0] = 42)")
let t9 = tokenize("arr[0] = 42")
println("Status: PASSED\n")

// Test 10
println("Test 10: Method Call (obj.method(arg1, arg2))")
let t10 = tokenize("obj.method(arg1, arg2)")
println("Status: PASSED\n")

